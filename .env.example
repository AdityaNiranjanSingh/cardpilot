# CardPilot environment
# Local default:
DATABASE_URL=sqlite:///data/card_rewards_mvp.db
# Production: use your Render/Railway/Supabase PostgreSQL connection string.
# DATABASE_URL=postgresql://user:password@host:5432/database

SECRET_KEY=replace-this-with-a-long-random-secret-before-hosting
SESSION_COOKIE_NAME=cardpilot_session
SESSION_DAYS=14
# Use 1 in production when your site has HTTPS.
SESSION_HTTPS_ONLY=0
APP_BASE_URL=http://127.0.0.1:8000
# For production, prefer your exact backend URL instead of *.
CORS_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

# Default local admin account. Change before putting online.
ADMIN_EMAIL=admin@cardpilot.local
ADMIN_NAME=CardPilot Admin
ADMIN_PASSWORD=Admin@12345
